# Provider mode: auto (default: live Overpass POIs where reachable, else offline)
#                | fixture (force fully offline) | osm (force self-hosted OSRM/Nominatim/Overpass)
PROVIDER_MODE=auto

# Backend database (docker compose sets this to the postgis service)
# DATABASE_URL=postgresql+psycopg2://apartment:apartment@db:5432/apartment_fit

# Real OSM providers (only used when PROVIDER_MODE=osm/auto)
# OSRM_URL=http://osrm:5000
# NOMINATIM_URL=http://nominatim:8080
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# For real Nominatim import, region extract to load:
# NOMINATIM_PBF_URL=https://download.geofabrik.de/north-america/us/washington-latest.osm.pbf

# Opt-in multi-user auth
# AUTH_ENABLED=false

# Saved-search alerts
# ALERT_INTERVAL_SECONDS=0            # >0 enables the background scheduler
# ALERT_NOTIFIER=console              # console | webhook | email
# ALERT_WEBHOOK_URL=https://hooks.example.com/...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_TO=you@example.com

# Live Seattle open-data sources (used by scripts/fetch_seattle_data.py)
# SPD_CRIME_URL=https://data.seattle.gov/resource/tazs-3rd5.json
# ELEVATION_URL=https://api.opentopodata.org/v1/ned10m
